# Human-readable app name used in logs and OpenAPI.
APP_NAME=LeadFlow AI API

# Runtime environment: development, staging or production.
APP_ENV=development

# Local bind address for manual runs.
APP_HOST=0.0.0.0

# Local port for manual runs; Railway injects PORT automatically in production.
APP_PORT=8000

# Database connection string. SQLite works locally; use PostgreSQL on Railway.
DATABASE_URL=sqlite:///./leadflow.db

# Allowed frontend origins, comma-separated.
CORS_ORIGINS=http://localhost:5173

# Demo credentials used by the product fallback and API auth.
DEMO_EMAIL=admin@leadflow.ai
DEMO_PASSWORD=123456

# Shared JWT secret for API authentication.
AUTH_JWT_SECRET=change-me-in-production

# Gemini integration toggle and credentials.
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=20
