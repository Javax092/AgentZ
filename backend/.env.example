# Human-readable app name used in logs and OpenAPI.
APP_NAME=LeadFlow AI API

# Runtime environment: development, staging or production.
APP_ENV=development

# Local bind address for manual runs.
APP_HOST=0.0.0.0

# Local port for manual runs; Railway injects PORT automatically in production.
APP_PORT=8000

# Database connection string. Use PostgreSQL locally and on Railway.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/leadflow

# Allowed frontend origins, comma-separated.
CORS_ORIGINS=http://localhost:5173

# Shared JWT secret for API authentication.
AUTH_JWT_SECRET=change-me-in-production
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_PASSWORD_ITERATIONS=600000

# Optional admin bootstrap on first start.
DEFAULT_ADMIN_NAME=LeadFlow Admin
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# Gemini integration toggle and credentials.
GEMINI_ENABLED=false
GEMINI_PROVIDER_NAME=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=20
